# ============================================================================
# REQUIRED: Anthropic API Configuration
# ============================================================================
# Get your API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# OPTIONAL: Arize Phoenix Configuration (observability — self-hosted)
# ============================================================================
# Phoenix is an open-source platform for LLM observability and tracing
#
# Start Phoenix locally:
#   python -m phoenix.server.main serve
#   → http://localhost:6006
#
# Traces include:
#   - Agent execution (planning, tool selection, response)
#   - Tool calls (search, validate, plan, review)
#   - Model invocations (Claude API, Ollama qwen2.5-coder)
#   - Token usage and latency metrics
#
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=terraform-agent
PHOENIX_ENABLED=true

# ============================================================================
# OPTIONAL: Model Routing Configuration (Phase 1 Optimization)
# ============================================================================
# Control which tasks use Ollama (local, free) vs Claude (API, paid)
#
# Options: summarization, parsing, review
#   - summarization: Condense knowledge base results (~30% token reduction)
#   - parsing: Parse terraform errors for root cause (~10% token reduction)
#   - review: Full code review against best practices (already local)
#
# Examples:
#   USE_OLLAMA_FOR=summarization,parsing,review  # Use Ollama for all 3 (max savings)
#   USE_OLLAMA_FOR=summarization,parsing         # Use Ollama for 2, Claude for review
#   USE_OLLAMA_FOR=                              # Use Claude for everything (no Ollama)
#
USE_OLLAMA_FOR=summarization,parsing,review

# Ollama model selection by task type
# Ensure models are pulled: ollama pull <model-name>
OLLAMA_SUMMARY_MODEL=qwen3.5:9b              # Larger model for quality summarization
OLLAMA_PARSE_MODEL=qwen2.5-coder:7b-instruct # Fast parsing
OLLAMA_REVIEW_MODEL=qwen2.5-coder:14b        # Larger model for code review (optional)
