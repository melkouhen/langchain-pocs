# ============================================================================
# REQUIRED: Anthropic API Configuration
# ============================================================================
# Get your API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# OPTIONAL: Langfuse Configuration (for agent tracing and observability)
# ============================================================================
# Langfuse is a production-grade LLM observability platform
# Tracing is automatically enabled when both keys are configured
#
# For Cloud Langfuse (recommended):
#   1. Sign up at https://langfuse.com
#   2. Create a project and get your keys from Project Settings > API Keys
#   3. Set LANGFUSE_BASE_URL=https://cloud.langfuse.com (default)
#
# For self-hosted Langfuse:
#   1. Deploy Langfuse locally or on your infrastructure
#   2. Set LANGFUSE_BASE_URL to your instance URL
#
# Traces include:
#   - Agent execution (planning, tool selection, response)
#   - Tool calls (knowledge base search, terraform validation)
#   - Token usage and latency metrics
#   - Error tracking and debugging context
#
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================================================
# OPTIONAL: LangSmith Configuration (alternative to Langfuse)
# ============================================================================
# LangSmith is LangChain's debugging and observability platform
# Note: Langfuse takes precedence if both are configured
#
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv_...
LANGCHAIN_PROJECT=terraform-agent
